  (:objects
    Y P R O - block
    C1 C2 C3 C4 - column
  )
  (:init
    (inColumn Y C1)
    (inColumn P C2)
    (inColumn R C3)
    (inColumn O C4)
    (clear Y)
    (clear P)
    (clear R)
    (clear O)
    (rightOf C2 C1)
    (rightOf C3 C1)
    (rightOf C3 C2)
    (rightOf C4 C1)
    (rightOf C4 C2)
    (rightOf C4 C3)
    (leftOf C1 C2)
    (leftOf C1 C3)
    (leftOf C2 C3)
    (leftOf C1 C4)
    (leftOf C2 C4)
    (leftOf C3 C4)
  )
  (:goal (and (clear Y)))
)
